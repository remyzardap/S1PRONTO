# ─── Sutaeru S1PRONTO — Environment Variables ───
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ══════════════════════════════════════════════════
# Core
# ══════════════════════════════════════════════════
NODE_ENV=production
PORT=3000
APP_URL=https://sutaeru.com

# ══════════════════════════════════════════════════
# Database (PostgreSQL)
# ══════════════════════════════════════════════════
DATABASE_URL=postgresql://sutaeru:changeme@localhost:5432/sutaeru
POSTGRES_DB=sutaeru
POSTGRES_USER=sutaeru
POSTGRES_PASSWORD=changeme

# ══════════════════════════════════════════════════
# Authentication & Security
# ══════════════════════════════════════════════════
JWT_SECRET=your-jwt-secret-here
SESSION_SECRET=your-session-secret-here

# ══════════════════════════════════════════════════
# AI Provider Keys
# ══════════════════════════════════════════════════

# Anthropic (Claude) — Primary for S1 + Max mode (Opus)
ANTHROPIC_API_KEY=sk-ant-...

# Kimi / Moonshot — Documentation & agentic tasks
KIMI_API_KEY=sk-...

# Google Gemini — Fallback + vision
GEMINI_API_KEY=AIza...

# Perplexity Sonar — Research & web search
SONAR_API_KEY=pplx-...

# OpenAI / LiteLLM — GPT-5.2 routing
OPENAI_API_KEY=sk-...
LITELLM_API_KEY=sk-...

# Google Vertex AI — Sovereign stack (Jakarta region)
VERTEX_API=
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=asia-southeast1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ══════════════════════════════════════════════════
# Voice AI (Kemma Calls — ElevenLabs)
# ══════════════════════════════════════════════════
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_AGENT_ID=
ELEVEN_LABS_VOICE_ID=

# ══════════════════════════════════════════════════
# File Storage (AWS S3)
# ══════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=sutaeru-files

# ══════════════════════════════════════════════════
# Payments (Stripe)
# ══════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ══════════════════════════════════════════════════
# Email (SMTP)
# ══════════════════════════════════════════════════
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@sutaeru.com

# ══════════════════════════════════════════════════
# Google Workspace OAuth
# ══════════════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ══════════════════════════════════════════════════
# WhatsApp / Telegram
# ══════════════════════════════════════════════════
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
TELEGRAM_BOT_TOKEN=

# ══════════════════════════════════════════════════
# Optional: Skip Google Secret Manager (dev mode)
# ══════════════════════════════════════════════════
SKIP_SECRET_MANAGER=true
